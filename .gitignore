# Old locations (kept for backward compatibility during migration)
logs/*
nushell/initializers
shells/bash/initializers
shells/fish/initializers
shells/zsh/initializers

# New XDG-compliant state directory (local machine state, not tracked)
.local/

# devenv generated files and cache
.devenv/
.devenv.flake.nix

# User configuration
yazelix.nix
yazelix.toml
yazelix_packs.toml
yazelix.toml.backup-*
yazelix_packs.toml.backup-*
user_configs/*
!user_configs/README.md
!user_configs/terminal/
user_configs/terminal/*
!user_configs/terminal/README.md
!user_configs/yazi/
user_configs/yazi/*
!user_configs/yazi/README.md
!user_configs/zellij/
user_configs/zellij/*
!user_configs/zellij/README.md
helix_custom/
configs/yazi/user/*
!configs/yazi/user/README.md
configs/yazi/personal/
configs/zellij/personal/*
!configs/zellij/personal/README.md

# Rust plugin build artifacts
rust_plugins/*/target/

# bv (beads viewer) local config and caches
.bv/

# Kiro local workspace/spec artifacts
.kiro/
