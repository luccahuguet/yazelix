{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yazelix.com/schemas/yazelix_settings.schema.json",
  "title": "Yazelix Settings",
  "description": "Canonical Yazelix config UI settings inventory. Main runtime settings use ~/.config/yazelix/settings.jsonc and config_metadata/main_config_contract.toml; cursor settings use the existing ~/.config/yazelix_ghostty_cursors/settings.jsonc compatibility path and are composed into the config UI under cursors.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "core",
    "helix",
    "editor",
    "workspace",
    "shell",
    "terminal",
    "zellij",
    "yazi"
  ],
  "x-yazelix": {
    "canonical_file": "settings.jsonc",
    "cursor_file": "~/.config/yazelix_ghostty_cursors/settings.jsonc",
    "main_contract": "config_metadata/main_config_contract.toml",
    "config_ui_metadata": "config_metadata/config_ui_metadata.toml",
    "cursor_default_template": "yazelix_ghostty_cursors_default.toml",
    "tabs": [
      "general",
      "workspace",
      "editor",
      "terminal",
      "appearance",
      "cursors",
      "status_bar",
      "file_manager",
      "keybindings",
      "shell",
      "advanced"
    ]
  },
  "properties": {
    "core": {
      "type": "object",
      "description": "General Yazelix runtime behavior and welcome screen settings",
      "required": [
        "debug_mode",
        "skip_welcome_screen",
        "show_macchina_on_welcome",
        "welcome_style",
        "game_of_life_cell_style",
        "welcome_duration_seconds"
      ],
      "additionalProperties": false,
      "properties": {
        "debug_mode": {
          "type": "boolean"
        },
        "skip_welcome_screen": {
          "type": "boolean"
        },
        "show_macchina_on_welcome": {
          "type": "boolean"
        },
        "welcome_style": {
          "type": "string",
          "enum": [
            "static",
            "logo",
            "boids",
            "boids_predator",
            "boids_schools",
            "mandelbrot",
            "game_of_life_gliders",
            "game_of_life_oscillators",
            "game_of_life_bloom",
            "random"
          ]
        },
        "game_of_life_cell_style": {
          "type": "string",
          "enum": [
            "full_block",
            "dotted"
          ]
        },
        "welcome_duration_seconds": {
          "type": "number",
          "minimum": 0.2,
          "maximum": 8.0
        }
      },
      "x-yazelix": {
        "tab": "general"
      }
    },
    "helix": {
      "type": "object",
      "description": "Helix-specific runtime integration settings",
      "required": [
        "external",
        "steel_plugins"
      ],
      "additionalProperties": false,
      "properties": {
        "external": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "required": [
                "binary",
                "runtime_path"
              ],
              "additionalProperties": false,
              "properties": {
                "binary": {
                  "type": "string"
                },
                "runtime_path": {
                  "type": "string"
                }
              }
            }
          ]
        },
        "steel_plugins": {
          "type": "object",
          "description": "Child-packaged bundled Helix Steel plugin ids plus user-owned plugin manifests copied from ~/.config/yazelix/helix/steel_plugins",
          "required": [
            "enabled",
            "extra"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9_.-]+$"
              },
              "uniqueItems": true
            },
            "extra": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "source"
                ],
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9_.-]+$"
                  },
                  "source": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9_./-]+\\.scm$",
                    "not": {
                      "anyOf": [
                        {
                          "pattern": "^/"
                        },
                        {
                          "pattern": "\\\\"
                        },
                        {
                          "pattern": "(^|/)\\.\\.?(/|$)"
                        },
                        {
                          "pattern": "//"
                        }
                      ]
                    }
                  },
                  "support_files": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9_./-]+\\.scm$",
                      "not": {
                        "anyOf": [
                          {
                            "pattern": "^/"
                          },
                          {
                            "pattern": "\\\\"
                          },
                          {
                            "pattern": "(^|/)\\.\\.?(/|$)"
                          },
                          {
                            "pattern": "//"
                          }
                        ]
                      }
                    },
                    "uniqueItems": true
                  },
                  "public_commands": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9_.!?+*/<=>-]+$"
                    }
                  },
                  "internal_commands": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9_.!?+*/<=>-]+$"
                    }
                  },
                  "startup_commands": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z0-9_.!?+*/<=>-]+$"
                    }
                  },
                  "command_descriptions": {
                    "type": "object",
                    "propertyNames": {
                      "pattern": "^[A-Za-z0-9_.!?+*/<=>-]+$"
                    },
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "startup_condition": {
                    "anyOf": [
                      {
                        "type": "null"
                      },
                      {
                        "type": "string",
                        "enum": [
                          "show_splash"
                        ]
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      },
      "x-yazelix": {
        "tab": "editor"
      }
    },
    "editor": {
      "type": "object",
      "description": "Editor command and editor integration settings",
      "required": [
        "command",
        "hide_sidebar_on_file_open"
      ],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string"
        },
        "hide_sidebar_on_file_open": {
          "type": "boolean"
        }
      },
      "x-yazelix": {
        "tab": "editor"
      }
    },
    "workspace": {
      "type": "object",
      "description": "Workspace sidebars and pane placement settings",
      "required": [
        "left_sidebar",
        "right_sidebar"
      ],
      "additionalProperties": false,
      "properties": {
        "left_sidebar": {
          "type": "object",
          "required": [
            "command",
            "args",
            "width_percent"
          ],
          "additionalProperties": false,
          "properties": {
            "command": {
              "type": "string"
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "width_percent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 48
            }
          }
        },
        "right_sidebar": {
          "type": "object",
          "required": [
            "command",
            "args",
            "width_percent"
          ],
          "additionalProperties": false,
          "properties": {
            "command": {
              "type": "string"
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "width_percent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 48
            }
          }
        }
      },
      "x-yazelix": {
        "tab": "workspace"
      }
    },
    "shell": {
      "type": "object",
      "description": "Default shell settings for Yazelix panes",
      "required": [
        "default_shell"
      ],
      "additionalProperties": false,
      "properties": {
        "default_shell": {
          "type": "string",
          "enum": [
            "nu",
            "bash",
            "fish",
            "zsh"
          ]
        }
      },
      "x-yazelix": {
        "tab": "shell"
      }
    },
    "terminal": {
      "type": "object",
      "description": "Active terminal transparency and config ownership settings",
      "required": [
        "config_mode",
        "transparency"
      ],
      "additionalProperties": false,
      "properties": {
        "config_mode": {
          "type": "string",
          "enum": [
            "yazelix",
            "user"
          ]
        },
        "transparency": {
          "type": "string",
          "enum": [
            "none",
            "very_low",
            "low",
            "medium",
            "high",
            "very_high",
            "super_high"
          ]
        }
      },
      "x-yazelix": {
        "tab": "terminal"
      }
    },
    "zellij": {
      "type": "object",
      "description": "Zellij chrome, widgets, popup, and screen-saver settings",
      "required": [
        "disable_tips",
        "pane_frames",
        "rounded_corners",
        "support_kitty_keyboard_protocol",
        "theme",
        "widget_tray",
        "tab_label_mode",
        "claude_usage_display",
        "codex_usage_display",
        "opencode_go_usage_display",
        "codex_usage_periods",
        "opencode_go_usage_periods",
        "claude_usage_periods",
        "custom_text",
        "popup_commands",
        "custom_popups",
        "popup_width_percent",
        "popup_height_percent",
        "screen_saver_enabled",
        "screen_saver_idle_seconds",
        "screen_saver_style",
        "default_mode",
        "native_keybindings",
        "keybindings"
      ],
      "additionalProperties": false,
      "properties": {
        "disable_tips": {
          "type": "boolean"
        },
        "pane_frames": {
          "type": "boolean"
        },
        "rounded_corners": {
          "type": "boolean"
        },
        "support_kitty_keyboard_protocol": {
          "type": "boolean"
        },
        "theme": {
          "type": "string"
        },
        "widget_tray": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "editor",
              "shell",
              "term",
              "workspace",
              "cursor",
              "claude_usage",
              "codex_usage",
              "opencode_go_usage",
              "cpu",
              "ram"
            ]
          }
        },
        "tab_label_mode": {
          "type": "string",
          "enum": [
            "full",
            "compact"
          ]
        },
        "claude_usage_display": {
          "type": "string",
          "enum": [
            "token",
            "quota",
            "both"
          ]
        },
        "codex_usage_display": {
          "type": "string",
          "enum": [
            "token",
            "quota",
            "both"
          ]
        },
        "codex_usage_periods": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "5h",
              "week"
            ]
          }
        },
        "opencode_go_usage_display": {
          "type": "string",
          "enum": [
            "token",
            "quota",
            "both"
          ]
        },
        "opencode_go_usage_periods": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "5h",
              "week",
              "month"
            ]
          }
        },
        "claude_usage_periods": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "5h",
              "week"
            ]
          }
        },
        "custom_text": {
          "type": "string"
        },
        "popup_commands": {
          "type": "object",
          "description": "Commands for built-in Yazelix popup surfaces",
          "required": [
            "bottom_popup",
            "top_popup",
            "menu"
          ],
          "additionalProperties": false,
          "properties": {
            "bottom_popup": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "top_popup": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "menu": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "custom_popups": {
          "type": "array",
          "description": "User-defined Yazelix popup surfaces",
          "items": {
            "type": "object",
            "required": [
              "id",
              "command",
              "keybindings"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
              },
              "command": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              },
              "keybindings": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "keep_alive": {
                "type": [
                  "boolean",
                  "null"
                ],
                "description": "Hide the focused popup on toggle instead of closing its process"
              }
            }
          }
        },
        "popup_width_percent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "popup_height_percent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "screen_saver_enabled": {
          "type": "boolean"
        },
        "screen_saver_idle_seconds": {
          "type": "integer",
          "minimum": 10,
          "maximum": 86400
        },
        "screen_saver_style": {
          "type": "string",
          "enum": [
            "logo",
            "boids",
            "boids_predator",
            "boids_schools",
            "mandelbrot",
            "game_of_life_gliders",
            "game_of_life_oscillators",
            "game_of_life_bloom",
            "random"
          ]
        },
        "default_mode": {
          "type": "string",
          "enum": [
            "normal",
            "locked"
          ]
        },
        "keybindings": {
          "type": "object",
          "description": "Semantic remaps for Yazelix-owned Zellij actions",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "native_keybindings": {
          "type": "object",
          "description": "Curated native Zellij key policy remaps and unbinds managed by Yazelix",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "x-yazelix": {
        "tab": "workspace"
      }
    },
    "yazi": {
      "type": "object",
      "description": "Yazi theme, plugin, sorting, and command settings",
      "required": [
        "command",
        "ya_command",
        "plugins",
        "theme",
        "sort_by",
        "keybindings"
      ],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string"
        },
        "ya_command": {
          "type": "string"
        },
        "plugins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "theme": {
          "type": "string"
        },
        "sort_by": {
          "type": "string",
          "enum": [
            "alphabetical",
            "natural",
            "modified",
            "created",
            "size"
          ]
        },
        "keybindings": {
          "type": "object",
          "description": "Semantic remaps for Yazelix-owned Yazi integration actions",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "x-yazelix": {
        "tab": "file_manager"
      }
    },
    "cursors": {
      "type": "object",
      "description": "Cursor preset, effect, and cursor definition registry",
      "required": [
        "schema_version",
        "enabled_cursors",
        "settings",
        "cursor"
      ],
      "additionalProperties": false,
      "x-yazelix": {
        "tab": "cursors"
      },
      "properties": {
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "enabled_cursors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "settings": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "trail": {
              "type": "string"
            },
            "trail_effect": {
              "type": "string",
              "enum": [
                "tail",
                "warp",
                "sweep",
                "random",
                "none"
              ]
            },
            "mode_effect": {
              "type": "string",
              "enum": [
                "ripple",
                "sonic_boom",
                "rectangle_boom",
                "ripple_rectangle",
                "random",
                "none"
              ]
            },
            "glow": {
              "type": "string",
              "enum": [
                "none",
                "low",
                "medium",
                "high"
              ]
            },
            "duration": {
              "type": "number",
              "minimum": 0.25,
              "maximum": 4.0
            },
            "kitty_enable_cursor": {
              "type": "boolean"
            }
          },
          "required": [
            "trail",
            "trail_effect",
            "mode_effect",
            "glow",
            "duration",
            "kitty_enable_cursor"
          ]
        },
        "cursor": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "family"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "family": {
                "type": "string",
                "enum": [
                  "mono",
                  "split"
                ]
              },
              "color": {
                "type": "string"
              },
              "accent_color": {
                "type": "string"
              },
              "colors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "divider": {
                "type": "string",
                "enum": [
                  "vertical",
                  "horizontal"
                ]
              },
              "transition": {
                "type": "string",
                "enum": [
                  "soft",
                  "hard"
                ]
              },
              "cursor_color": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}
