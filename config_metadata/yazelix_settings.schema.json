{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yazelix.com/schemas/yazelix_settings.schema.json",
  "title": "Yazelix Settings",
  "description": "Canonical sparse Yazelix Nova root inventory. Native tool configs and cursor settings remain separate sidecars under ~/.config/yazelix/.",
  "type": "object",
  "additionalProperties": false,
  "x-yazelix": {
    "canonical_file": "config.toml",
    "cursor_file": "~/.config/yazelix/cursors.toml",
    "main_contract": "config_metadata/main_config_contract.toml",
    "config_ui_metadata": "config_metadata/config_ui_metadata.toml",
    "cursor_default_template": "child package share/yazelix/yazelix_cursors/cursors.toml",
    "tabs": [
      "general",
      "workspace",
      "editor",
      "terminal",
      "appearance",
      "cursors",
      "status_bar",
      "file_manager",
      "keybindings",
      "shell",
      "advanced"
    ]
  },
  "properties": {
    "open": {
      "type": "object",
      "description": "Managed open diagnostics",
      "additionalProperties": false,
      "properties": {
        "log_level": {
          "type": "string",
          "enum": [
            "off",
            "error",
            "info",
            "debug"
          ]
        }
      }
    },
    "shell": {
      "type": "object",
      "description": "Packaged shell selection",
      "additionalProperties": false,
      "properties": {
        "program": {
          "type": "string",
          "enum": [
            "nu",
            "bash",
            "zsh",
            "fish"
          ]
        }
      }
    },
    "editor": {
      "type": "object",
      "description": "Managed editor selection",
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S+$"
        }
      }
    },
    "agent": {
      "type": "object",
      "description": "Managed agent command",
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S+$"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "welcome": {
      "type": "object",
      "description": "Startup welcome behavior",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "style": {
          "type": "string",
          "enum": [
            "static",
            "logo",
            "boids",
            "boids_predator",
            "boids_schools",
            "mandelbrot",
            "game_of_life_gliders",
            "game_of_life_oscillators",
            "game_of_life_bloom",
            "random"
          ]
        },
        "duration_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        }
      }
    },
    "popup": {
      "type": "object",
      "description": "Managed popup margins",
      "additionalProperties": false,
      "properties": {
        "side_margin": {
          "type": "integer",
          "minimum": 0
        },
        "vertical_margin": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "keybindings": {
      "type": "object",
      "description": "Managed popup key chords",
      "additionalProperties": false,
      "properties": {
        "config": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "git": {
          "type": "string",
          "minLength": 1
        },
        "menu": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "bar": {
      "type": "object",
      "description": "Top-bar widget order",
      "additionalProperties": false,
      "properties": {
        "widgets": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "session",
              "editor",
              "shell",
              "term",
              "claude_usage",
              "codex_usage",
              "opencode_go_usage",
              "cpu",
              "ram"
            ]
          }
        }
      }
    },
    "popups": {
      "type": "object",
      "description": "Custom managed popup definitions keyed by stable id",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "object",
        "description": "Custom managed popup",
        "required": [
          "command",
          "keybinding"
        ],
        "additionalProperties": false,
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\S+$"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": ".*\\S.*"
            }
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "pattern": ".*\\S.*"
          },
          "keybinding": {
            "type": "string",
            "minLength": 1
          },
          "keep_alive": {
            "type": "boolean"
          }
        }
      }
    },
    "cursors": {
      "type": "object",
      "description": "Cursor preset, effect, and cursor definition registry",
      "required": [
        "schema_version",
        "enabled_cursors",
        "settings",
        "cursor"
      ],
      "additionalProperties": false,
      "x-yazelix": {
        "tab": "cursors"
      },
      "properties": {
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "enabled_cursors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "settings": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "trail": {
              "type": "string"
            },
            "trail_effect": {
              "type": "string",
              "enum": [
                "tail",
                "warp",
                "sweep",
                "random",
                "none"
              ]
            },
            "mode_effect": {
              "type": "string",
              "enum": [
                "ripple",
                "sonic_boom",
                "rectangle_boom",
                "ripple_rectangle",
                "random",
                "none"
              ]
            },
            "glow": {
              "type": "string",
              "enum": [
                "none",
                "low",
                "medium",
                "high"
              ]
            },
            "duration": {
              "type": "number",
              "minimum": 0.25,
              "maximum": 4
            },
            "kitty_enable_cursor": {
              "type": "boolean"
            }
          },
          "required": [
            "trail",
            "trail_effect",
            "mode_effect",
            "glow",
            "duration",
            "kitty_enable_cursor"
          ]
        },
        "cursor": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "family"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "family": {
                "type": "string",
                "enum": [
                  "mono",
                  "split"
                ]
              },
              "color": {
                "type": "string"
              },
              "accent_color": {
                "type": "string"
              },
              "colors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "divider": {
                "type": "string",
                "enum": [
                  "vertical",
                  "horizontal"
                ]
              },
              "transition": {
                "type": "string",
                "enum": [
                  "soft",
                  "hard"
                ]
              },
              "cursor_color": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}
