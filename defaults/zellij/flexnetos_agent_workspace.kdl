// FlexNetOS workspace expressed through the canonical Yazelix Nova runtime.
layout {
    cwd "/home/flexnetos/FlexNetOS"

    tab name="FlexNetOS" focus=true {
        pane size=1 borderless=true {
            @bar@
        }
        pane split_direction="vertical" {
            pane name="sidebar" command="@yazi@" size="20%"
            pane name="workspace" command="@shell@" size="20%"
            pane name="agent" command="@agent@" size="40%"
            pane name="tools" command="@shell@" size="20%"
        }
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }

    tab name="Mission Control" {
        pane size=1 borderless=true {
            @bar@
        }
        pane name="ccboard" command="@ccboard@"
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }
}
