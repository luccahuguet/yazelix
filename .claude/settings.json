{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "br ready --limit 10",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "br ready --limit 10",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "git-kb daemon status --quiet >/dev/null 2>&1 || git-kb daemon start --background >/dev/null 2>&1",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  }
}