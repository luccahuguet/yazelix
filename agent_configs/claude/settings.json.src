{
  "permissions": {
    "defaultMode": "dontAsk"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/flexnetos/.nix-profile/toolbin/rtk hook claude"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/flexnetos/.nix-profile/toolbin/icm hook pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/flexnetos/.nix-profile/toolbin/icm hook post"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/flexnetos/.nix-profile/toolbin/icm hook compact"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/flexnetos/.nix-profile/toolbin/icm hook prompt"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/flexnetos/.nix-profile/toolbin/icm hook start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/flexnetos/.nix-profile/toolbin/icm hook end"
          }
        ]
      }
    ]
  },
  "effortLevel": "xhigh",
  "askUserQuestionTimeout": "never",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "editorMode": "normal",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
