[Unit]
Description=Watch profile-owned FlexNetOS host cache policy inputs

[Path]
PathChanged=/etc/nix/nix.conf
PathChanged=/etc/nix/nix.custom.conf
PathChanged=/etc/determinate/config.json
PathChanged=/etc/shells
PathChanged=/etc/systemd/journald.conf.d/10-yazelix-no-persistent.conf
PathChanged=/etc/docker/daemon.json
PathChanged=/etc/opt/chrome/policies/managed/yazelix-storage.json
Unit=yazelix_host_policy.service

[Install]
WantedBy=multi-user.target
